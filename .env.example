# EmailJS (required only if you want the contact form to send messages)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_USER_ID=

# Canonical site URL (recommended for local/prod SEO consistency)
NEXT_PUBLIC_SITE_URL=https://luxtraveler.eu

# Optional server-side override
SITE_URL=https://luxtraveler.eu
